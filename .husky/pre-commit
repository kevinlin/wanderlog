# Exit on any error: a red test suite or a failed format blocks the commit.
set -e

pnpm test

# --- Auto-format staged files with Ultracite ---
#
# No stashing. The previous stash push/pop dance merged stale pre-format file
# contents back over the freshly formatted ones whenever the formatter changed
# a staged file, leaving conflict markers in the working tree and an orphaned
# stash. Instead:
#   - fully staged files are formatted in place and re-staged (working tree
#     and index stay identical for them, so there is nothing to restore);
#   - partially staged files are skipped with a warning, because re-adding
#     them would sweep their unstaged hunks into the commit.

STAGED=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$STAGED" ]; then
  echo "No staged files to format"
  exit 0
fi

UNSTAGED=$(git diff --name-only)
BEFORE=$(git diff --cached | git hash-object --stdin)

# Collect fully staged files as positional parameters (space-safe in POSIX sh).
set --
while IFS= read -r file; do
  [ -f "$file" ] || continue
  if printf '%s\n' "$UNSTAGED" | grep -qxF "$file"; then
    echo "⚠️  $file is partially staged - not auto-formatted (run 'npx ultracite fix' yourself)"
    continue
  fi
  set -- "$@" "$file"
done <<EOF
$STAGED
EOF

if [ $# -gt 0 ]; then
  pnpm exec ultracite fix "$@"
  git add "$@"
fi

AFTER=$(git diff --cached | git hash-object --stdin)
if [ "$BEFORE" != "$AFTER" ]; then
  echo "✨ Files formatted by Ultracite"
fi
